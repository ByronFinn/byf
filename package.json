{
  "name": "@byfriends/monorepo",
  "version": "0.3.2",
  "private": true,
  "description": "BYF (Be Your Friend) monorepo for terminal AI agent tooling",
  "homepage": "https://github.com/ByronFinn/byf",
  "license": "MIT",
  "author": "ByronFinn",
  "repository": {
    "type": "git",
    "url": "https://github.com/ByronFinn/byf.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "build:packages": "pnpm -r --filter './packages/*' run build",
    "dev:cli": "pnpm -C apps/cli run dev",
    "vis": "pnpm -C apps/vis run dev",
    "dev:docs": "pnpm -C docs install --ignore-workspace && pnpm -C docs run dev",
    "typecheck": "pnpm run build:packages && pnpm -r --filter './packages/*' run typecheck && pnpm --filter @byfriends/cli run typecheck",
    "lint": "oxlint --type-aware",
    "lint:fix": "pnpm run lint --fix",
    "lint:pkg": "pnpm -r --filter '!@byfriends/monorepo' exec publint && node scripts/attw-pkg.mjs",
    "fmt": "oxfmt",
    "fmt:check": "pnpm run fmt --check",
    "sherif": "sherif",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "pnpm -r run clean",
    "changeset": "changeset",
    "version": "changeset version",
    "publish": "pnpm run typecheck && pnpm run lint && pnpm run fmt:check && pnpm run sherif && pnpm run test && pnpm run build && pnpm run lint:pkg && changeset publish",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.30.0",
    "@mariozechner/clipboard": "^0.3.9",
    "@microsoft/api-extractor": "7.58.7",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "4.1.4",
    "lint-staged": "16.4.0",
    "oxfmt": "^0.55.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "publint": "0.3.18",
    "sherif": "1.11.1",
    "simple-git-hooks": "2.13.1",
    "tsdown": "0.22.0",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
      "oxfmt --write",
      "oxlint --fix --quiet",
      "oxlint --type-aware --quiet"
    ]
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
