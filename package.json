{
  "name": "@byfriends/monorepo",
  "version": "0.3.2",
  "private": true,
  "description": "BYF (Be Your Friend) monorepo for terminal AI agent tooling",
  "homepage": "https://github.com/ByronFinn/byf",
  "license": "MIT",
  "author": "ByronFinn",
  "repository": {
    "type": "git",
    "url": "https://github.com/ByronFinn/byf.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "apps/cli/npm/*",
    "apps/vis/shared",
    "apps/vis/server",
    "apps/vis/web",
    "docs"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run --filter './packages/*' build && bun run --filter '@byfriends/cli' build && bun run build:vis",
    "build:packages": "bun run --filter './packages/*' build",
    "build:vis": "bun run --filter '@byfriends/vis-web' build && bun run --filter '@byfriends/vis-server' build",
    "build:docs": "bun run --filter 'byf-docs' build",
    "dev:cli": "bun run --cwd apps/cli dev",
    "vis": "bun run --filter '@byfriends/vis-server' dev",
    "dev:docs": "bun run --filter 'byf-docs' dev",
    "typecheck": "bun run build:packages && bun run build:vis && bun run --filter './packages/*' typecheck && bun run --filter '@byfriends/cli' typecheck",
    "typecheck:tests": "bun x tsc -p tsconfig.test.json --noEmit",
    "lint": "oxlint --type-aware",
    "lint:fix": "bun run lint --fix",
    "lint:pkg": "bun scripts/publint-pkg.mjs && bun scripts/attw-pkg.mjs",
    "pubcheck:manifest": "bun scripts/check-published-manifest.mjs",
    "fmt": "oxfmt",
    "fmt:check": "bun run fmt --check",
    "sherif": "sherif",
    "test": "bun build/run-tests.mjs",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "clean": "bun run --filter '*' clean",
    "changeset": "changeset",
    "version": "changeset version",
    "publish": "bun run typecheck && bun run lint && bun run fmt:check && bun run sherif && bun run test && bun run build && bun run lint:pkg && bun run pubcheck:manifest && bun scripts/with-publish-manifests.mjs changeset publish",
    "prepare": "simple-git-hooks",
    "test:serial": "bun test"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.30.0",
    "@mariozechner/clipboard": "^0.3.9",
    "@microsoft/api-extractor": "7.58.7",
    "@types/bun": "1.3.14",
    "@types/node": "^22.20.1",
    "lint-staged": "16.4.0",
    "oxfmt": "^0.55.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "publint": "0.3.18",
    "sherif": "1.11.1",
    "simple-git-hooks": "2.13.1",
    "typescript": "6.0.2"
  },
  "overrides": {
    "ssh2@1.17.0>cpu-features": "-",
    "ssh2@1.17.0>nan": "-"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
      "oxfmt --write",
      "oxlint --fix --quiet",
      "oxlint --type-aware --quiet"
    ]
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "packageManager": "bun@1.3.14",
  "catalog": {
    "zod": "^4.3.6"
  },
  "trustedDependencies": [
    "esbuild",
    "koffi",
    "protobufjs"
  ]
}
