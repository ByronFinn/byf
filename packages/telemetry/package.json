{
  "name": "@byf/telemetry",
  "version": "0.0.1",
  "private": true,
  "description": "Shared telemetry infrastructure for Kimi Code",
  "license": "MIT",
  "author": "ByronFinn",
  "homepage": "https://github.com/ByronFinn/byf/tree/main/packages/telemetry#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ByronFinn/byf.git",
    "directory": "packages/telemetry"
  },
  "bugs": {
    "url": "https://github.com/ByronFinn/byf/issues"
  },
  "keywords": [
    "kimi",
    "telemetry",
    "analytics",
    "events",
    "client"
  ],
  "files": [
    "dist"
  ],
  "type": "module",
  "imports": {
    "#/*": [
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  }
}
