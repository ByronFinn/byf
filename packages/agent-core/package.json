{
  "name": "@byfriends/agent-core",
  "version": "0.3.6",
  "description": "Unified agent engine for BYF",
  "keywords": [
    "agent",
    "ai",
    "byf",
    "session",
    "terminal",
    "tools"
  ],
  "homepage": "https://github.com/ByronFinn/byf",
  "bugs": {
    "url": "https://github.com/ByronFinn/byf/issues"
  },
  "license": "MIT",
  "author": "ByronFinn",
  "repository": {
    "type": "git",
    "url": "https://github.com/ByronFinn/byf.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "imports": {
    "#/*": [
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./agent/records/migration": {
      "types": "./src/agent/records/migration/index.ts",
      "default": "./src/agent/records/migration/index.ts"
    },
    "./session/store": {
      "types": "./src/session/store/index.ts",
      "default": "./src/session/store/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      },
      "./agent/records/migration": {
        "types": "./dist/agent/records/migration/index.d.mts",
        "import": "./dist/agent/records/migration/index.mjs",
        "default": "./dist/agent/records/migration/index.mjs"
      },
      "./session/store": {
        "types": "./dist/session/store/index.d.mts",
        "import": "./dist/session/store/index.mjs",
        "default": "./dist/session/store/index.mjs"
      }
    },
    "access": "public",
    "provenance": false
  },
  "scripts": {
    "build": "tsdown && node scripts/rewrite-dts-subpaths.mjs",
    "test": "vitest run",
    "test:baseline": "vitest run",
    "typecheck": "tsc --build",
    "clean": "rm -rf dist && rm -rf dist-types"
  },
  "dependencies": {
    "@antfu/utils": "^9.3.0",
    "@byfriends/kaos": "workspace:^",
    "@byfriends/kosong": "workspace:^",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.1",
    "linkedom": "^0.18.12",
    "nunjucks": "^3.2.4",
    "open": "^10.2.0",
    "picomatch": "^4.0.4",
    "proper-lockfile": "^4.1.2",
    "regexp.escape": "^2.0.1",
    "retry": "0.13.1",
    "smol-toml": "^1.6.1",
    "tar": "^7.5.13",
    "undici": "^8.4.1",
    "yauzl": "^3.3.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/nunjucks": "^3.2.6",
    "@types/picomatch": "^4.0.3",
    "@types/proper-lockfile": "^4.1.4",
    "@types/regexp.escape": "^2.0.0",
    "@types/retry": "0.12.0",
    "@types/tar": "^7.0.87",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^2.4.6",
    "yazl": "^3.3.1"
  }
}
