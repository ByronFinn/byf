{
  "name": "@byf/sdk",
  "version": "0.0.1",
  "private": true,
  "description": "Public TypeScript SDK for BYF agents and sessions",
  "license": "Proprietary",
  "author": "ByronFinn",
  "homepage": "https://github.com/ByronFinn/byf",
  "repository": {
    "type": "git",
    "url": "https://github.com/ByronFinn/byf.git"
  },
  "bugs": {
    "url": "https://github.com/ByronFinn/byf/issues"
  },
  "keywords": [
    "byf",
    "sdk",
    "typescript",
    "agent",
    "api"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "imports": {
    "#/*": [
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      }
    },
    "provenance": true
  },
  "scripts": {
    "build": "tsdown && pnpm run build:dts || true",
    "build:dts": "node scripts/build-dts.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .tmp-api-extractor"
  },
  "dependencies": {
    "@antfu/utils": "^9.3.0",
    "smol-toml": "^1.6.1",
    "yazl": "^3.3.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@byf/agent-core": "workspace:^",
    "@byf/kaos": "workspace:^",
    "@byf/oauth": "workspace:^",
    "@byf/kosong": "workspace:^",
    "@types/yazl": "^2.4.6"
  }
}
