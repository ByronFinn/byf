{
  "name": "@byfriends/kosong",
  "version": "0.3.2",
  "description": "LLM and provider abstraction layer for BYF",
  "license": "Proprietary",
  "author": "ByronFinn",
  "homepage": "https://github.com/ByronFinn/byf",
  "repository": {
    "type": "git",
    "url": "https://github.com/ByronFinn/byf.git"
  },
  "bugs": {
    "url": "https://github.com/ByronFinn/byf/issues"
  },
  "keywords": [
    "byf",
    "llm",
    "ai",
    "agent",
    "provider"
  ],
  "files": [
    "dist"
  ],
  "type": "module",
  "imports": {
    "#/*": [
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./providers/*": {
      "types": "./src/providers/*.ts",
      "default": "./src/providers/*.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      },
      "./providers/openai-responses": {
        "types": "./dist/providers/openai-responses.d.mts",
        "import": "./dist/providers/openai-responses.mjs",
        "default": "./dist/providers/openai-responses.mjs"
      },
      "./providers/anthropic": {
        "types": "./dist/providers/anthropic.d.mts",
        "import": "./dist/providers/anthropic.mjs",
        "default": "./dist/providers/anthropic.mjs"
      },
      "./providers/google-genai": {
        "types": "./dist/providers/google-genai.d.mts",
        "import": "./dist/providers/google-genai.mjs",
        "default": "./dist/providers/google-genai.mjs"
      },
      "./providers/openai-common": {
        "types": "./dist/providers/openai-common.d.mts",
        "import": "./dist/providers/openai-common.mjs",
        "default": "./dist/providers/openai-common.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@google/genai": "^1.49.0",
    "openai": "^6.34.0",
    "zod": "catalog:",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1"
  }
}
