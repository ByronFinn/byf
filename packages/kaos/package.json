{
  "name": "@byf/kaos",
  "version": "0.0.1",
  "private": true,
  "description": "Execution environment and filesystem/process abstractions for BYF",
  "license": "Proprietary",
  "author": "ByronFinn",
  "homepage": "https://github.com/ByronFinn/byf",
  "repository": {
    "type": "git",
    "url": "https://github.com/ByronFinn/byf.git"
  },
  "bugs": {
    "url": "https://github.com/ByronFinn/byf/issues"
  },
  "keywords": [
    "byf",
    "agent",
    "execution",
    "sandbox",
    "process",
    "filesystem"
  ],
  "files": [
    "dist"
  ],
  "type": "module",
  "imports": {
    "#/*": [
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./ssh": {
      "types": "./src/ssh.ts",
      "default": "./src/ssh.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/ssh2": "^1.15.5"
  }
}
