{
  "name": "@byfriends/oauth",
  "version": "1.0.0",
  "description": "Authentication utilities for BYF",
  "license": "Proprietary",
  "author": "ByronFinn",
  "homepage": "https://github.com/ByronFinn/byf",
  "repository": {
    "type": "git",
    "url": "https://github.com/ByronFinn/byf.git"
  },
  "bugs": {
    "url": "https://github.com/ByronFinn/byf/issues"
  },
  "keywords": [
    "byf",
    "authentication",
    "oauth",
    "api-key",
    "cli"
  ],
  "files": [
    "dist"
  ],
  "type": "module",
  "imports": {
    "#/*": [
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  }
}
