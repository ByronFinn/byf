{
  "name": "@byfriends/vis-server",
  "version": "0.3.6",
  "description": "HTTP server for BYF session visualization, serving the API and built SPA assets",
  "keywords": [
    "byf",
    "debugging",
    "server",
    "vis",
    "visualization"
  ],
  "homepage": "https://github.com/ByronFinn/byf",
  "bugs": {
    "url": "https://github.com/ByronFinn/byf/issues"
  },
  "license": "MIT",
  "author": "ByronFinn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ByronFinn/byf.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "imports": {
    "#/*": [
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "exports": {
    ".": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false,
    "exports": {
      ".": {
        "types": "./dist/server.d.mts",
        "import": "./dist/server.mjs",
        "default": "./dist/server.mjs"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun ../../../build/bun-lib-build.mjs ./src/server.ts ./src/index.ts --bundle-workspace && bun scripts/build-dts.mjs && bun ../scripts/copy-web-dist.mjs",
    "test": "bun test"
  },
  "dependencies": {
    "@byfriends/agent-core": "workspace:^",
    "@hono/node-server": "^1.13.7",
    "hono": "^4.7.7"
  },
  "devDependencies": {
    "@byfriends/kosong": "workspace:*",
    "@byfriends/vis-web": "workspace:*"
  }
}
