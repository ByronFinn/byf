{
  "name": "@byfriends/vis",
  "version": "0.3.2",
  "private": true,
  "description": "Visual debugging tools for BYF sessions and replays",
  "license": "Proprietary",
  "type": "module",
  "scripts": {
    "build:deps": "pnpm --filter @byfriends/agent-core... build",
    "predev": "pnpm run build:deps",
    "dev": "node scripts/dev.mjs",
    "build": "pnpm run build:deps && pnpm --filter @byfriends/vis-server build && pnpm --filter @byfriends/vis-web build && node scripts/copy-web-dist.mjs",
    "prestart": "pnpm run build",
    "start": "node server/dist/server.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "author": "ByronFinn",
  "homepage": "https://github.com/ByronFinn/byf",
  "repository": {
    "type": "git",
    "url": "https://github.com/ByronFinn/byf.git"
  },
  "keywords": [
    "byf",
    "visualizer",
    "debugging",
    "sessions",
    "replay"
  ]
}
